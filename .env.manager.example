# Recommended panel + Creator supervisor stack (portainer-stack.yml).
WLB_IMAGE=ghcr.io/sereza111/whitelist-bypass-portainer:v0.5.0-alpha.11

# Required by the manager. Use a unique password of at least 12 characters.
PANEL_USERNAME=admin
PANEL_PASSWORD=replace-with-a-long-random-password

# Read-only fallback cookie directory on the Docker host.
WLB_SECRETS_DIR=/opt/whitelist-bypass/secrets

# Runtime defaults. Profiles can override supported values in the panel.
MAX_SESSIONS=4
AUTO_START=false
CREATOR_MODE=vk
RESOURCES=default
DISPLAY_NAME=Headless
VIDEO_RELIABILITY=auto
KCP_PROFILE=balanced

# Optional legacy/global VK recovery recipient. Prefer the panel global setting
# or a per-profile recipient for multi-user deployments.
VK_PEER_ID=

# Optional Creator egress SOCKS5 sidecar.
UPSTREAM_SOCKS=
UPSTREAM_USER=
UPSTREAM_PASS=
