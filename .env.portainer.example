# Image built by this repository's GitHub Actions workflow.
WLB_IMAGE=ghcr.io/your-github-user/your-repository:latest

# Required: VK community API credentials.
VK_TOKEN=vk1.a.your-community-access-token
VK_GROUP_ID=123456789

# Strongly recommended: comma-separated VK user IDs allowed to control the bot.
# Empty means that anyone who can message the community may start sessions.
VK_USER_IDS=123456789

# default | moderate | unlimited
RESOURCES=default

# Optional SOCKS5 upstream. It must support UDP ASSOCIATE.
UPSTREAM_SOCKS=
UPSTREAM_USER=
UPSTREAM_PASS=
