# Prebuilt image from this repository.
WLB_IMAGE=ghcr.io/sereza111/whitelist-bypass-portainer:latest

# vk | telemost | wbstream | dion
CREATOR_MODE=vk

# Directory on the Docker host containing cookies-*.json.
WLB_SECRETS_DIR=/opt/whitelist-bypass/secrets

# moderate | default | unlimited
RESOURCES=default
DISPLAY_NAME=Headless

# Optional: rejoin an existing call instead of creating a new one.
EXISTING_LINK=

# Optional SOCKS5 upstream. It must support UDP ASSOCIATE.
UPSTREAM_SOCKS=
UPSTREAM_USER=
UPSTREAM_PASS=
